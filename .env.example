API_ID=your_api_id
API_HASH=your_api_hash
BOT_TOKEN=your_bot_token_from_botfather
# PHONE is only needed when you intentionally run as a user account.
PHONE=
CHAT_GROUPS=group_username_or_id
ALLOW_ALL_CHATS=false
DEDUPE_TTL_SECONDS=1800
DASHBOARD_API_KEY=change_me_before_using_tunnel
FIREBASE_SERVICE_ACCOUNT=service-account.json
FIRESTORE_SYNC_FINDINGS=false

# Frontend build env (set in frontend/.env.local or hosting build env)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=haumea-cupons.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=haumea-cupons
VITE_FIREBASE_STORAGE_BUCKET=haumea-cupons.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
