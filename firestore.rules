rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    // Usuários: próprio usuário lê/escreve
    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // Regras/produtos: leitura e escrita apenas para admins.
    match /products/{productId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Findings: bot usa Admin SDK e ignora rules; painel admin le e pode limpar.
    match /findings/{findingId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    // Chat groups: leitura e escrita apenas para admins.
    match /chat_groups/{groupId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
    match /{document=**} { allow read, write: if false; }
  }
}
